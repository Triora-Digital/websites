    <!-- ============================= RSVP ============================= -->
    <section class="section rsvp" id="rsvp" aria-labelledby="rsvp-title">
      <div class="container container--narrow">
        <header class="section__head reveal" data-reveal>
          <p class="eyebrow">Will you join us?</p>
          <h2 class="section__title" id="rsvp-title">RSVP</h2>
          <span class="divider" aria-hidden="true"><span class="divider__diamond"></span></span>
          <p class="section__lead">Kindly reply by 15 January 2027 so we can prepare your place.</p>
        </header>

        <div class="rsvp__card glass reveal" data-reveal>
          <form class="rsvp__form" id="rsvpForm" novalidate>
            <div class="field field--full">
              <span class="field__label">Will you be attending?</span>
              <div class="choice" role="radiogroup" aria-label="Will you be attending?">
                <label class="choice__opt">
                  <input type="radio" name="attending" value="yes" required>
                  <span class="choice__pill">Joyfully accept</span>
                </label>
                <label class="choice__opt">
                  <input type="radio" name="attending" value="no">
                  <span class="choice__pill">Regretfully decline</span>
                </label>
              </div>
            </div>

            <div class="field">
              <label class="field__label" for="rsvpName">Full name</label>
              <input class="field__input" id="rsvpName" name="name" type="text" autocomplete="name" required placeholder="Your full name">
              <span class="field__error" data-error-for="name"></span>
            </div>

            <div class="field">
              <label class="field__label" for="rsvpEmail">Email</label>
              <input class="field__input" id="rsvpEmail" name="email" type="email" autocomplete="email" required placeholder="you@example.com">
              <span class="field__error" data-error-for="email"></span>
            </div>

            <div class="field">
              <label class="field__label" for="rsvpPhone">Phone</label>
              <input class="field__input" id="rsvpPhone" name="phone" type="tel" autocomplete="tel" placeholder="+61 400 000 000">
              <span class="field__error" data-error-for="phone"></span>
            </div>

            <div class="field" data-attending-only>
              <label class="field__label" for="rsvpGuests">Number attending</label>
              <select class="field__input" id="rsvpGuests" name="guests">
                <option value="1">1 — just me</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
              </select>
            </div>

            <div class="field field--full" data-attending-only>
              <label class="field__label" for="rsvpDiet">Dietary requirements</label>
              <input class="field__input" id="rsvpDiet" name="dietary" type="text" placeholder="Vegetarian, gluten-free, allergies…">
            </div>

            <div class="field field--full" data-attending-only>
              <label class="field__label" for="rsvpSong">Song request</label>
              <input class="field__input" id="rsvpSong" name="song" type="text" placeholder="A song to fill the dance floor">
            </div>

            <div class="field field--full">
              <label class="field__label" for="rsvpMessage">A note for the couple <span class="field__opt">(optional)</span></label>
              <textarea class="field__input field__textarea" id="rsvpMessage" name="message" rows="3" placeholder="Share your well wishes…"></textarea>
            </div>

            <div class="field field--full rsvp__submit">
              <button type="submit" class="btn btn--gold btn--block" id="rsvpSubmit">Send our reply</button>
              <p class="rsvp__privacy">Your details are saved only on this device for the couple's planning.</p>
            </div>
          </form>

          <!-- Confirmation -->
          <div class="rsvp__confirm" id="rsvpConfirm" hidden>
            <span class="rsvp__confirm-mark" aria-hidden="true">
              <svg viewBox="0 0 52 52"><circle class="rsvp__confirm-circle" cx="26" cy="26" r="24" fill="none"/><path class="rsvp__confirm-check" fill="none" d="M14 27l8 8 16-16"/></svg>
